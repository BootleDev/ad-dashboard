AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appIyePhrYZBUxCP9
ANTHROPIC_API_KEY=
# Required. Auth fails closed when unset (no default) — WEBDEV-211. The login
# cookie is HMAC(this, context), so changing it logs everyone out.
DASHBOARD_PASSWORD=

# WEBDEV-194: Supabase read path. Must be the TRANSACTION POOLER URL
# (...pooler.supabase.com:6543). Server-side only — never expose to the client.
SUPABASE_DB_URL=

# Per-table kill switches: set to "airtable" to force the legacy Airtable path
# for that table even when SUPABASE_DB_URL is present. Unset = Supabase first,
# fail-fast to Airtable on any error / timeout / empty result.
# AD_SNAPSHOTS_SOURCE=airtable
# DAILY_AGGREGATES_SOURCE=airtable
# AD_ALERTS_SOURCE=airtable
# SHOPIFY_SALES_SOURCE=airtable
